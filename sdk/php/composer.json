{
  "name": "fluxchat/sdk",
  "description": "Official FluxChat SDK for PHP",
  "type": "library",
  "license": "MIT",
  "version": "1.0.0",
  "authors": [
    {
      "name": "benjaminmugangu"
    }
  ],
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "FluxChat\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "FluxChat\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit tests/"
  }
}
